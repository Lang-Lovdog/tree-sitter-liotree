{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "liotree",
  "rules": {
    "source_file": {
      "type": "SYMBOL",
      "name": "root"
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "file_entry"
        },
        {
          "type": "SYMBOL",
          "name": "directory_entry"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "root": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "root_bar"
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directory_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        },
        {
          "type": "FIELD",
          "name": "contents",
          "content": {
            "type": "SYMBOL",
            "name": "content_block"
          }
        }
      ]
    },
    "root_bar": {
      "type": "STRING",
      "value": "|"
    },
    "entry_bar": {
      "type": "STRING",
      "value": "|"
    },
    "format_space": {
      "type": "PATTERN",
      "value": "\\ "
    },
    "depth_mark": {
      "type": "PATTERN",
      "value": "[-+]"
    },
    "scope_delimiter_open": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "pipe",
            "content": {
              "type": "STRING",
              "value": "|"
            }
          },
          {
            "type": "FIELD",
            "name": "level",
            "content": {
              "type": "STRING",
              "value": "="
            }
          },
          {
            "type": "FIELD",
            "name": "end",
            "content": {
              "type": "STRING",
              "value": "-"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "scope_delimiter_closed": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "pipe",
            "content": {
              "type": "STRING",
              "value": "|"
            }
          },
          {
            "type": "FIELD",
            "name": "level",
            "content": {
              "type": "STRING",
              "value": "="
            }
          },
          {
            "type": "FIELD",
            "name": "end",
            "content": {
              "type": "STRING",
              "value": "="
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "file_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "entry_bar"
        },
        {
          "type": "FIELD",
          "name": "bridge",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "depth_mark"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "leaf",
          "content": {
            "type": "SYMBOL",
            "name": "depth_mark"
          }
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "file_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "directory_entry": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "entry_bar"
          },
          {
            "type": "FIELD",
            "name": "bridge",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SYMBOL",
                    "name": "depth_mark"
                  }
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          },
          {
            "type": "FIELD",
            "name": "leaf",
            "content": {
              "type": "SYMBOL",
              "name": "depth_mark"
            }
          },
          {
            "type": "STRING",
            "value": " "
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "directory_name"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "scope_delimiter_open"
                  },
                  {
                    "type": "FIELD",
                    "name": "contents",
                    "content": {
                      "type": "SYMBOL",
                      "name": "content_block"
                    }
                  },
                  {
                    "type": "SYMBOL",
                    "name": "scope_delimiter_closed"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "directory_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^-+|>\\s][^|>\\n]*\\/['\"]{0,1}"
        },
        {
          "type": "FIELD",
          "name": "formatspace",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "format_space"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "file_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^-+|>\\s][^|>\\/\\n\\s]*"
            },
            {
              "type": "PATTERN",
              "value": "\\\"[^|>\\/\\n]*\\\""
            },
            {
              "type": "PATTERN",
              "value": "\\'[^|>\\/\\n]*\\'"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "formatspace",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "format_space"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "content_block": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment_open"
        },
        {
          "type": "SYMBOL",
          "name": "comment_text"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "comment_closed"
        }
      ]
    },
    "comment_open": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ">"
      }
    },
    "comment_closed": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "||"
      }
    },
    "comment_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^|\\n]+"
      }
    },
    "comment_newline": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "PATTERN",
            "value": "\\n\\ *"
          }
        },
        {
          "type": "SYMBOL",
          "name": "comment_bar"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "PATTERN",
            "value": "\\ *"
          }
        }
      ]
    },
    "comment_bar": {
      "type": "STRING",
      "value": "|"
    },
    "comment_content": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment_newline"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PREC",
                "value": 2,
                "content": {
                  "type": "SYMBOL",
                  "name": "comment_newline"
                }
              },
              {
                "type": "PREC",
                "value": 1,
                "content": {
                  "type": "SYMBOL",
                  "name": "comment_text"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\s\\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}